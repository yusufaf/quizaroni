# ---- CDK deploy target ----
account=123456789012
region=us-west-2
appName=quizaroni
# development | production
deploymentType=development

# ---- Cognito (public client config, supply your own pool) ----
DEV_USER_POOL_ID=
DEV_USER_POOL_CLIENT_ID=
PROD_USER_POOL_ID=
PROD_USER_POOL_CLIENT_ID=

# ---- CORS ----
# Comma-separated extra origins allowed by the API (localhost is always allowed)
ALLOWED_ORIGINS=https://your-frontend.example.com

# ---- Google OAuth (optional; required only if enabling Google sign-in) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
